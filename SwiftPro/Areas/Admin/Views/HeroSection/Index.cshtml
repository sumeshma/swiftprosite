@model SwiftPro.Models.HeroSection

@{
    ViewData["Title"] = "Hero Section Management";
}

<div class="container-fluid py-4">

    <div class="row justify-content-center">

        <div class="col-xl-10">

            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                <div class="card-header bg-dark text-white p-4 border-0">

                    <h2 class="fw-bold mb-1">
                        Hero Section Management
                    </h2>

                    <p class="mb-0 text-light">
                        Manage the homepage hero section content dynamically.
                    </p>

                </div>

                <div class="card-body p-4 p-lg-5">

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success rounded-3">
                            @TempData["Success"]
                        </div>
                    }

                    <div asp-validation-summary="All"
                         class="alert alert-danger rounded-3">
                    </div>

                    <form method="post">

                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="Id" />

                        <!-- Badge Text -->

                        <div class="mb-4">

                            <label asp-for="BadgeText"
                                   class="form-label fw-semibold">
                                Badge Text
                            </label>

                            <input asp-for="BadgeText"
                                   class="form-control form-control-lg rounded-3"
                                   placeholder="Enter badge text" />

                            <span asp-validation-for="BadgeText"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- Hero Title -->

                        <div class="mb-4">

                            <label asp-for="Title"
                                   class="form-label fw-semibold">
                                Hero Title
                            </label>

                            <textarea asp-for="Title"
                                  class="form-control rounded-3"
                                  rows="3"
                                      placeholder="Enter hero title">
                            </textarea>

                            <span asp-validation-for="Title"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- Subtitle -->

                        <div class="mb-5">

                            <label asp-for="Subtitle"
                                   class="form-label fw-semibold">
                                Hero Subtitle
                            </label>

                            <textarea asp-for="Subtitle"
                                  class="form-control rounded-3"
                                  rows="5"
                                      placeholder="Enter hero subtitle">
                            </textarea>

                            <span asp-validation-for="Subtitle"
                                  class="text-danger">
                            </span>

                        </div>

                        <div class="row">

                            <!-- Primary Button Text -->

                            <div class="col-md-6 mb-4">

                                <label asp-for="PrimaryButtonText"
                                       class="form-label fw-semibold">
                                    Primary Button Text
                                </label>

                                <input asp-for="PrimaryButtonText"
                                       class="form-control rounded-3"
                                       placeholder="Book a Discovery Call" />

                            </div>

                            <!-- Primary Button URL -->

                            <div class="col-md-6 mb-4">

                                <label asp-for="PrimaryButtonUrl"
                                       class="form-label fw-semibold">
                                    Primary Button URL
                                </label>

                                <input asp-for="PrimaryButtonUrl"
                                       class="form-control rounded-3"
                                       placeholder="/Contact" />

                            </div>

                            <!-- Secondary Button Text -->

                            <div class="col-md-6 mb-4">

                                <label asp-for="SecondaryButtonText"
                                       class="form-label fw-semibold">
                                    Secondary Button Text
                                </label>

                                <input asp-for="SecondaryButtonText"
                                       class="form-control rounded-3"
                                       placeholder="View Portfolio" />

                            </div>

                            <!-- Secondary Button URL -->

                            <div class="col-md-6 mb-4">

                                <label asp-for="SecondaryButtonUrl"
                                       class="form-label fw-semibold">
                                    Secondary Button URL
                                </label>

                                <input asp-for="SecondaryButtonUrl"
                                       class="form-control rounded-3"
                                       placeholder="/Portfolio" />

                            </div>

                        </div>

                        <div class="d-flex justify-content-end mt-4">

                            <button type="submit"
                                    class="btn btn-dark btn-lg rounded-3 px-5">
                                Save Changes
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}