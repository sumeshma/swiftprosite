@using Microsoft.AspNetCore.Identity
@using SwiftPro.Models.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var title = ViewData["Title"]?.ToString() ?? "Control Panel";
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title | SwiftPro Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
</head>
<body class="admin-body">
    <div class="admin-shell">
        <aside class="admin-sidebar">
            <a class="admin-brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <span class="admin-brand-mark">S</span>
                <span>
                    <strong>SwiftPro</strong>
                    <small>Enterprise CMS</small>
                </span>
            </a>

            <nav class="admin-nav" aria-label="Admin navigation">
                <a class="admin-nav-link @(currentController == "Dashboard" ? "active" : "")" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-speedometer2"></i>
                    Dashboard
                </a>
                <a class="admin-nav-link @(currentController == "Pages" ? "active" : "")" asp-area="Admin" asp-controller="Pages" asp-action="Index">
                    <i class="bi bi-file-earmark-richtext"></i>
                    Pages
                </a>
                <a class="admin-nav-link @(currentController == "HomePageSettings" ? "active" : "")" asp-area="Admin" asp-controller="HomePageSettings" asp-action="Index">
                    <i class="bi bi-house-gear"></i>
                    Home Page
                </a>
                <a class="admin-nav-link @(currentController == "Messages" ? "active" : "")" asp-area="Admin" asp-controller="Messages" asp-action="Index">
                    <i class="bi bi-envelope-paper"></i>
                    Messages
                </a>
                <a class="admin-nav-link @(currentController == "Menu" ? "active" : "")" asp-area="Admin" asp-controller="Menu" asp-action="Index">
                    <i class="bi bi-list-stars"></i>
                    Menu Builder
                </a>
                <a class="admin-nav-link @(currentController == "HeaderFooter" ? "active" : "")" asp-area="Admin" asp-controller="HeaderFooter" asp-action="Index">
                    <i class="bi bi-layout-three-columns"></i>
                    Header & Footer
                </a>
                <a class="admin-nav-link @(currentController == "Media" ? "active" : "")" asp-area="Admin" asp-controller="Media" asp-action="Index">
                    <i class="bi bi-images"></i>
                    Media Library
                </a>
                <a class="admin-nav-link @(currentController == "HeroSection" ? "active" : "")" asp-area="Admin" asp-controller="HeroSection" asp-action="Index">
                    <i class="bi bi-stars"></i>
                    Hero Section
                </a>
                <a class="admin-nav-link @(currentController == "Settings" ? "active" : "")" asp-area="Admin" asp-controller="Settings" asp-action="Index">
                    <i class="bi bi-sliders"></i>
                    Appearance
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <a class="admin-nav-link @(currentController == "Users" ? "active" : "")" asp-area="Admin" asp-controller="Users" asp-action="Index">
                        <i class="bi bi-people"></i>
                        Users
                    </a>
                    <a class="admin-nav-link @(currentController == "Roles" ? "active" : "")" asp-area="Admin" asp-controller="Roles" asp-action="Index">
                        <i class="bi bi-shield-check"></i>
                        Roles
                    </a>
                }
            </nav>

            <div class="admin-sidebar-footer">
                <a class="admin-nav-link" asp-area="" asp-controller="Home" asp-action="Index" target="_blank">
                    <i class="bi bi-box-arrow-up-right"></i>
                    View Website
                </a>
            </div>
        </aside>

        <div class="admin-main">
            <header class="admin-topbar">
                <div>
                    <p class="admin-eyebrow mb-1">Control Panel</p>
                    <h1>@title</h1>
                </div>
                @if (SignInManager.IsSignedIn(User))
                {
                    <div class="admin-user">
                        <span class="admin-user-avatar">@((User.Identity?.Name ?? "A").Substring(0, 1).ToUpperInvariant())</span>
                        <span class="d-none d-sm-inline">@User.Identity?.Name</span>
                        <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            <button class="btn btn-outline-danger btn-sm" type="submit">
                                <i class="bi bi-box-arrow-right"></i>
                                Logout
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <a class="btn btn-primary" asp-area="Admin" asp-controller="Account" asp-action="Login">
                        <i class="bi bi-box-arrow-in-right"></i>
                        Login
                    </a>
                }
            </header>

            <main class="admin-content">
                @if (TempData["Success"] is string success)
                {
                    <div class="alert alert-success admin-alert">
                        <i class="bi bi-check-circle-fill"></i>
                        @success
                    </div>
                }

                @if (TempData["Error"] is string error)
                {
                    <div class="alert alert-danger admin-alert">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        @error
                    </div>
                }

                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
