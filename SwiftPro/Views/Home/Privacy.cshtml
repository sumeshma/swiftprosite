@{
    ViewData["Title"] = "Privacy Policy";
}

<section class="py-5 bg-white">
    <div class="container py-5">
        <h1 class="section-title mb-3">@ViewData["Title"]</h1>
        <p class="text-secondary">SwiftPro Solutions respects your privacy. This policy outlines how we collect, use, and protect your information.</p>

        <h5 class="mt-4">Information we collect</h5>
        <p class="text-secondary">We collect contact information submitted through forms, such as name, email, subject, and message details.</p>

        <h5 class="mt-4">How we use information</h5>
        <p class="text-secondary">Your data is used only for responding to inquiries, service communication, and improving our offerings.</p>

        <h5 class="mt-4">Data protection</h5>
        <p class="text-secondary">We use reasonable technical and organizational safeguards to protect your information.</p>
    </div>
</section>
